# ============================================================
# BEME MARKET — FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — only .env.example is committed.
# All variables must be prefixed VITE_ to be accessible in Vite.
# ============================================================

# ── FIREBASE ─────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=        # Optional — only needed if using Firebase Analytics

# ── BACKEND API ──────────────────────────────────────────────
# Your Render backend URL (no trailing slash)
# Local:      http://localhost:10000
# Production: https://beme-market-1.onrender.com
VITE_API_URL=

# ── PAYSTACK ─────────────────────────────────────────────────
# Public key only — never put the secret key in the frontend
# Found in Paystack Dashboard → Settings → API Keys & Webhooks
VITE_PAYSTACK_PUBLIC_KEY=

# ── CLOUDINARY ───────────────────────────────────────────────
# Found in Cloudinary Dashboard → Settings → Upload → Upload presets
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
