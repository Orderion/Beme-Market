rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function role() {
      return userExists() ? userData().role : "guest";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return role() == "super_admin" || role() == "admin";
    }

    function isShopAdmin() {
      return role() == "shop_admin";
    }

    function isAdmin() {
      return isSuperAdmin() || isShopAdmin();
    }

    function isCustomer() {
      return role() == "customer";
    }

    function validString(value, min, max) {
      return value is string
        && value.size() >= min
        && value.size() <= max;
    }

    function validOptionalString(value, max) {
      return value == null || (value is string && value.size() <= max);
    }

    function optionalStringField(obj, key, max) {
      return !(key in obj)
        || obj[key] == null
        || (obj[key] is string && obj[key].size() <= max);
    }

    function validNumber(value) {
      return value is int || value is float;
    }

    function validBoolean(value) {
      return value is bool;
    }

    // ── Review validation ─────────────────────────────────────────
    function validReviewCreate() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          "name", "userId", "rating", "comment",
          "createdAt", "helpful", "verified"
        ])
        && d.rating is int
        && d.rating >= 1
        && d.rating <= 5
        && d.comment is string
        && d.comment.size() >= 3
        && d.comment.size() <= 1000
        && d.helpful == 0
        && d.verified is bool
        && (
          !("name" in d)
          || d.name == null
          || (d.name is string && d.name.size() <= 80)
        )
        && (
          d.userId == null
          || (signedIn() && d.userId == request.auth.uid)
        );
    }

    function validHelpfulUpdate() {
      let d = request.resource.data;
      let prev = resource.data;
      return d.diff(prev).affectedKeys().hasOnly(["helpful"])
        && d.helpful == prev.helpful + 1;
    }

    function orderAllowedCreateKeys() {
      return request.resource.data.keys().hasOnly([
        "userId",
        "items",
        "customer",
        "pricing",
        "status",
        "paymentMethod",
        "paymentStatus",
        "reference",
        "createdAt",
        "updatedAt",
        "emailSent",
        "paid",
        "shippingAddress",
        "address",
        "deliveryAddress",
        "shops",
        "primaryShop",
        "orderNumber",
        "source",
        "orderFingerprint",
        "verifyLock",
        "paystack",
        "fulfillmentStatus",
        "supplierPushStatus",
        "adminReviewed",
        "adminApproved",
        "approvedBy",
        "approvedAt",
        "rejectedBy",
        "rejectedAt",
        "heldBy",
        "heldAt",
        "reviewNotes",
        "supplierId",
        "supplierApiType",
        "supplierOrderId",
        "supplierStatus",
        "syncAttempts",
        "lastSyncError",
        "supplierTrackingNumber",
        "supplierTrackingUrl",
        "supplierPushKey",
        "supplierPushResponseSummary",
        "reviewFlags",
        "stockCheckSummary"
      ]);
    }

    function validCustomerObject() {
      return request.resource.data.customer is map
        && request.resource.data.customer.keys().hasOnly([
          "firstName",
          "lastName",
          "email",
          "phone",
          "address",
          "city",
          "region",
          "country",
          "landmark",
          "area",
          "notes",
          "network"
        ])
        && validString(request.resource.data.customer.firstName, 1, 80)
        && validString(request.resource.data.customer.lastName, 1, 80)
        && validString(request.resource.data.customer.email, 3, 160)
        && validString(request.resource.data.customer.phone, 7, 30)
        && optionalStringField(request.resource.data.customer, "address", 300)
        && optionalStringField(request.resource.data.customer, "city", 80)
        && optionalStringField(request.resource.data.customer, "region", 80)
        && optionalStringField(request.resource.data.customer, "country", 80)
        && optionalStringField(request.resource.data.customer, "landmark", 200)
        && optionalStringField(request.resource.data.customer, "area", 120)
        && optionalStringField(request.resource.data.customer, "notes", 500)
        && optionalStringField(request.resource.data.customer, "network", 40);
    }

    function validPricingObject() {
      return request.resource.data.pricing is map
        && request.resource.data.pricing.keys().hasOnly([
          "subtotal",
          "deliveryFee",
          "total",
          "currency",
          "supplierItemsCostTotal",
          "supplierShippingTotal",
          "expectedProfit",
          "expectedProfitMargin"
        ])
        && validNumber(request.resource.data.pricing.subtotal)
        && validNumber(request.resource.data.pricing.deliveryFee)
        && validNumber(request.resource.data.pricing.total)
        && request.resource.data.pricing.subtotal >= 0
        && request.resource.data.pricing.deliveryFee >= 0
        && request.resource.data.pricing.total >= 0
        && (
          !("supplierItemsCostTotal" in request.resource.data.pricing)
          || (
            validNumber(request.resource.data.pricing.supplierItemsCostTotal)
            && request.resource.data.pricing.supplierItemsCostTotal >= 0
          )
        )
        && (
          !("supplierShippingTotal" in request.resource.data.pricing)
          || (
            validNumber(request.resource.data.pricing.supplierShippingTotal)
            && request.resource.data.pricing.supplierShippingTotal >= 0
          )
        )
        && (
          !("expectedProfit" in request.resource.data.pricing)
          || validNumber(request.resource.data.pricing.expectedProfit)
        )
        && (
          !("expectedProfitMargin" in request.resource.data.pricing)
          || validNumber(request.resource.data.pricing.expectedProfitMargin)
        )
        && (
          !("currency" in request.resource.data.pricing)
          || validString(request.resource.data.pricing.currency, 1, 10)
        );
    }

    function validItemsList() {
      return request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 100;
    }

    function validOrderCreateStatus() {
      return request.resource.data.status in [
        "pending",
        "pending_payment",
        "paid",
        "awaiting_admin_review"
      ];
    }

    function validPaymentMethod() {
      return request.resource.data.paymentMethod in ["cod", "paystack"];
    }

    function validPaymentStatusOnCreate() {
      return request.resource.data.paymentStatus in ["pending", "paid"];
    }

    function validPaidFlagOnCreate() {
      return request.resource.data.paid is bool;
    }

    function validEmailSentFlag() {
      return !("emailSent" in request.resource.data)
        || validBoolean(request.resource.data.emailSent);
    }

    function validReferenceField() {
      return !("reference" in request.resource.data)
        || request.resource.data.reference == null
        || validString(request.resource.data.reference, 0, 200);
    }

    function validOrderFingerprintField() {
      return !("orderFingerprint" in request.resource.data)
        || request.resource.data.orderFingerprint == null
        || validString(request.resource.data.orderFingerprint, 0, 200);
    }

    function validVerifyLockField() {
      return !("verifyLock" in request.resource.data)
        || validBoolean(request.resource.data.verifyLock);
    }

    function validSourceField() {
      return !("source" in request.resource.data)
        || request.resource.data.source == null
        || validString(request.resource.data.source, 1, 40);
    }

    function validPrimaryShopField() {
      return !("primaryShop" in request.resource.data)
        || request.resource.data.primaryShop == null
        || validString(request.resource.data.primaryShop, 1, 60);
    }

    function validShopsField() {
      return !("shops" in request.resource.data)
        || request.resource.data.shops is list;
    }

    function validDropshipFieldsOnCreate() {
      return (
        !("fulfillmentStatus" in request.resource.data)
        || request.resource.data.fulfillmentStatus in [
          "awaiting_payment",
          "paid",
          "awaiting_admin_review",
          "approved_for_supplier",
          "held",
          "rejected",
          "sent_to_supplier",
          "supplier_confirmed",
          "shipped",
          "delivered",
          "failed"
        ]
      )
      && (
        !("supplierPushStatus" in request.resource.data)
        || request.resource.data.supplierPushStatus in [
          "not_sent",
          "queued",
          "sent",
          "confirmed",
          "failed"
        ]
      )
      && (
        !("adminReviewed" in request.resource.data)
        || validBoolean(request.resource.data.adminReviewed)
      )
      && (
        !("adminApproved" in request.resource.data)
        || validBoolean(request.resource.data.adminApproved)
      )
      && (
        !("approvedBy" in request.resource.data)
        || validOptionalString(request.resource.data.approvedBy, 200)
      )
      && (
        !("rejectedBy" in request.resource.data)
        || validOptionalString(request.resource.data.rejectedBy, 200)
      )
      && (
        !("heldBy" in request.resource.data)
        || validOptionalString(request.resource.data.heldBy, 200)
      )
      && (
        !("reviewNotes" in request.resource.data)
        || validOptionalString(request.resource.data.reviewNotes, 2000)
      )
      && (
        !("supplierId" in request.resource.data)
        || validOptionalString(request.resource.data.supplierId, 120)
      )
      && (
        !("supplierApiType" in request.resource.data)
        || validOptionalString(request.resource.data.supplierApiType, 80)
      )
      && (
        !("supplierOrderId" in request.resource.data)
        || validOptionalString(request.resource.data.supplierOrderId, 200)
      )
      && (
        !("supplierStatus" in request.resource.data)
        || validOptionalString(request.resource.data.supplierStatus, 120)
      )
      && (
        !("syncAttempts" in request.resource.data)
        || validNumber(request.resource.data.syncAttempts)
      )
      && (
        !("lastSyncError" in request.resource.data)
        || validOptionalString(request.resource.data.lastSyncError, 2000)
      )
      && (
        !("supplierTrackingNumber" in request.resource.data)
        || validOptionalString(request.resource.data.supplierTrackingNumber, 200)
      )
      && (
        !("supplierTrackingUrl" in request.resource.data)
        || validOptionalString(request.resource.data.supplierTrackingUrl, 500)
      )
      && (
        !("supplierPushKey" in request.resource.data)
        || validOptionalString(request.resource.data.supplierPushKey, 200)
      )
      && (
        !("reviewFlags" in request.resource.data)
        || request.resource.data.reviewFlags is list
      )
      && (
        !("stockCheckSummary" in request.resource.data)
        || request.resource.data.stockCheckSummary is map
      );
    }

    function validOrderOwnership() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    function validOrderCreateShape() {
      return orderAllowedCreateKeys()
        && validOrderOwnership()
        && validItemsList()
        && validCustomerObject()
        && validPricingObject()
        && validPaymentMethod()
        && validOrderCreateStatus()
        && validPaymentStatusOnCreate()
        && validPaidFlagOnCreate()
        && validEmailSentFlag()
        && validReferenceField()
        && validOrderFingerprintField()
        && validVerifyLockField()
        && validSourceField()
        && validPrimaryShopField()
        && validShopsField()
        && validDropshipFieldsOnCreate();
    }

    function validCodOrderCreate() {
      return request.resource.data.paymentMethod == "cod"
        && request.resource.data.paymentStatus == "pending"
        && request.resource.data.paid == false
        && request.resource.data.status == "pending";
    }

    function validPaystackOrderCreate() {
      return request.resource.data.paymentMethod == "paystack"
        && request.resource.data.reference is string
        && request.resource.data.reference.size() >= 0
        && request.resource.data.reference.size() <= 200
        && (
          (request.resource.data.paymentStatus == "pending"
            && request.resource.data.paid == false
            && request.resource.data.status == "pending_payment")
          ||
          (request.resource.data.paymentStatus == "paid"
            && request.resource.data.paid == true
            && request.resource.data.status == "paid")
        );
    }

    function orderCoreFieldsUnchanged() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.items == resource.data.items
        && request.resource.data.customer == resource.data.customer
        && request.resource.data.pricing == resource.data.pricing
        && request.resource.data.paymentMethod == resource.data.paymentMethod
        && request.resource.data.reference == resource.data.reference
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function customerOrderUpdateAllowed() {
      return signedIn()
        && resource.data.userId == request.auth.uid
        && orderCoreFieldsUnchanged()
        && request.resource.data.status == resource.data.status
        && request.resource.data.paymentStatus == resource.data.paymentStatus
        && request.resource.data.paid == resource.data.paid
        && request.resource.data.emailSent == resource.data.emailSent
        && request.resource.data.fulfillmentStatus == resource.data.fulfillmentStatus
        && request.resource.data.supplierPushStatus == resource.data.supplierPushStatus
        && request.resource.data.adminReviewed == resource.data.adminReviewed
        && request.resource.data.adminApproved == resource.data.adminApproved
        && request.resource.data.approvedBy == resource.data.approvedBy
        && request.resource.data.approvedAt == resource.data.approvedAt
        && request.resource.data.rejectedBy == resource.data.rejectedBy
        && request.resource.data.rejectedAt == resource.data.rejectedAt
        && request.resource.data.heldBy == resource.data.heldBy
        && request.resource.data.heldAt == resource.data.heldAt
        && request.resource.data.reviewNotes == resource.data.reviewNotes
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.supplierApiType == resource.data.supplierApiType
        && request.resource.data.supplierOrderId == resource.data.supplierOrderId
        && request.resource.data.supplierStatus == resource.data.supplierStatus
        && request.resource.data.syncAttempts == resource.data.syncAttempts
        && request.resource.data.lastSyncError == resource.data.lastSyncError
        && request.resource.data.supplierTrackingNumber == resource.data.supplierTrackingNumber
        && request.resource.data.supplierTrackingUrl == resource.data.supplierTrackingUrl
        && request.resource.data.supplierPushKey == resource.data.supplierPushKey;
    }

    // ── Products ──────────────────────────────────────────────────
    //
    // WHY allow read: if true
    // ──────────────────────
    // Firestore security rules using resource.data in a collection-level rule
    // break ALL queries against that collection. Firestore cannot pre-evaluate
    // resource.data for every document in a query without reading them, so it
    // rejects the entire query with a permission-denied error.
    //
    // Option A custom-request products (isCustomRequest: true, allowedUserId,
    // expiresAt) are kept private at the APPLICATION level:
    //   • The product detail page checks isCustomRequest + allowedUserId and
    //     shows "not available" to anyone who is not the intended customer.
    //   • The buy/order buttons are hidden for non-owners and expired links.
    //   • A random visitor would need to guess the exact Firestore document ID
    //     to even attempt a read — the URL is never surfaced in any listing.
    //
    // Only super_admin can create / update / delete product documents.
    match /Products/{productId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();

      // ── Product Reviews subcollection ─────────────────────────
      match /reviews/{reviewId} {
        allow read: if true;

        allow create: if validReviewCreate();

        allow update: if isSuperAdmin()
          || (signedIn() && resource.data.userId == request.auth.uid)
          || validHelpfulUpdate();

        allow delete: if isSuperAdmin()
          || (signedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // ── Weekly Offers ─────────────────────────────────────────────
    match /WeeklyOffers/{offerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Flash Deals ───────────────────────────────────────────────
    match /FlashDeals/{dealId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // ── Homepage config ───────────────────────────────────────────
    // Public read so the live homepage can fetch it without auth.
    // Only super_admin / admin roles can write.
    match /homepage/{document} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isSuperAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.role == "customer";

      allow update: if (
          isOwner(uid)
          && request.resource.data.role == resource.data.role
        )
        || isSuperAdmin();

      allow delete: if false;

      match /wishlist/{productId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Orders ────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if isCustomer()
        && validOrderCreateShape()
        && (validCodOrderCreate() || validPaystackOrderCreate());

      allow read: if isSuperAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);

      allow update: if isSuperAdmin()
        || customerOrderUpdateAllowed();

      allow delete: if isSuperAdmin();
    }

    match /shopApplications/{applicationId} {
      allow read, write: if isSuperAdmin();
    }

    match /payoutRequests/{requestId} {
      allow read, write: if isSuperAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin();
    }

    // ── Product Requests ──────────────────────────────────────────
    // Customers submit requests for products they can't find.
    // Admin actions (status changes, linking products) are super_admin only.
    // The chat subcollection is scoped to participants only.
    match /product_requests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && validString(request.resource.data.productName, 2, 120)
        && validString(request.resource.data.description, 5, 1000)
        && request.resource.data.status == "pending";

      allow read: if isSuperAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);

      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();

      // ── Request Chat Messages ─────────────────────────────────
      // Both the requesting customer and super_admin can read/send messages.
      // A message can only be created by the sender themselves (senderId == uid).
      // Only the isRead field can be updated by participants (marks as read).
      // Only super_admin can delete messages.
      match /messages/{messageId} {

        // Read: super_admin sees all; customer sees only their own request's chat
        allow read: if isSuperAdmin()
          || (signedIn()
              && get(/databases/$(database)/documents/product_requests/$(requestId)).data.userId
                 == request.auth.uid);

        // Create: must be a participant; senderId must equal own uid; text is required
        allow create: if signedIn()
          && (
            isSuperAdmin()
            || get(/databases/$(database)/documents/product_requests/$(requestId)).data.userId
               == request.auth.uid
          )
          && request.resource.data.senderId == request.auth.uid
          && validString(request.resource.data.text, 1, 1000)
          && request.resource.data.keys().hasOnly([
            "senderId", "senderRole", "senderName",
            "text", "createdAt", "isRead"
          ]);

        // Update: participants may only flip isRead (mark as read)
        allow update: if isSuperAdmin()
          || (signedIn()
              && get(/databases/$(database)/documents/product_requests/$(requestId)).data.userId
                 == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]));

        allow delete: if isSuperAdmin();
      }
    }

    // ── Admin Notifications ───────────────────────────────────────
    match /admin_notifications/{notifId} {
      allow read, write: if isSuperAdmin();
    }

    // ── User Notifications ────────────────────────────────────────
    match /user_notifications/{notifId} {
      allow create: if isSuperAdmin();

      allow read: if isSuperAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);

      // Users may only mark their own notifications as read
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]);

      allow delete: if isSuperAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
