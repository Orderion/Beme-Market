    "logs":   "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin":     "^12.0.0",
    "firebase-functions": "^4.9.0",
    "nodemailer":         "^6.9.13"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.3.0"
  },
  "private": true
}