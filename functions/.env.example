# ============================================================
# BEME MARKET — FIREBASE CLOUD FUNCTIONS ENVIRONMENT VARIABLES
# Set these with: firebase functions:config:set  (legacy)
# Or for Gen2 functions: add to functions/.env
# ============================================================

# ── EMAIL (BREVO) ────────────────────────────────────────────
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
BREVO_FROM_NAME=Beme Market
BREVO_FROM_EMAIL=

# ── TOTP / 2FA ENCRYPTION ────────────────────────────────────
# MUST be exactly 64 hexadecimal characters (= 32 bytes for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=
