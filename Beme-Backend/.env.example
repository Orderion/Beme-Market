# ============================================================
# BEME MARKET — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — only .env.example is committed.
# On Render: set these in Dashboard → Environment → Environment Variables
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
PORT=10000
NODE_ENV=production                  # production | development

# ── FIREBASE ADMIN ───────────────────────────────────────────
# Full JSON content of your Firebase service account key (single line, no line breaks)
# Found in Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON as one line. Wrap special chars if needed.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── PAYSTACK ─────────────────────────────────────────────────
# Secret key — NEVER expose this in the frontend
# Found in Paystack Dashboard → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=

# ── URLS ─────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://bememarket.store
# Your Render backend URL (no trailing slash)
BACKEND_URL=https://beme-market-1.onrender.com

# ── EMAIL (BREVO / Sendinblue) ───────────────────────────────
# Found in Brevo Dashboard → SMTP & API → SMTP
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
BREVO_FROM_NAME=Beme Market
BREVO_FROM_EMAIL=

# ── ANTHROPIC AI ─────────────────────────────────────────────
# Found in console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
